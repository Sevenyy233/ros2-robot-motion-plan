  <!--IMU-->
  <link name="imu_link">
    <visual>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
    </visual>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 1.65" rpy="0 0 0"/>
  </joint>

  <!-- 传动系统 -->
  <transmission name="left_back_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="left_wheel_back_joint">
      <hardwareInterface>hardware_interface/velocity</hardwareInterface>
    </joint>
    <actuator name="left_back_motor">
      <hardwareInterface>hardware_interface/velocity</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <transmission name="left_middle_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="left_wheel_middle_joint">
