<?xml version="1.0"?>
<robot name="terrain_with_cylinder">

  <link name="world"/>

  <!-- 1. 上坡 -->
  <joint name="joint_up" type="fixed">
    <parent link="world"/>
    <child link="slope_up"/>
    <origin xyz="4 0 0" rpy="0 -0.2618 0"/>
  </joint>

  <link name="slope_up">
    <visual>
      <origin xyz="10 0 0.05" rpy="0 0 0"/>
      <geometry><box size="20 10 0.1"/></geometry>
      <material name="green"><color rgba="0 1 0 1"/></material>
    </visual>
    <collision>
      <origin xyz="10 0 0.05" rpy="0 0 0"/>
      <geometry><box size="20 10 0.1"/></geometry>
    </collision>
    <inertial>
      <mass value="200.0"/>
      <inertia ixx="1666.8" ixy="0" ixz="0" iyy="6666.8" iyz="0" izz="8333.3"/>
    </inertial>
  </link>

  <!-- 2. 圆柱体 (放在上坡和平台的衔接处) -->
  <joint name="joint_cylinder" type="fixed">
    <parent link="slope_up"/>
    <child link="transition_cylinder"/>
    <!-- 移动到上坡末端，rpy 使其横向并保持水平姿态 -->
    <origin xyz="20 0 -0.9" rpy="1.5708 0.2618 0"/>
  </joint>

  <link name="transition_cylinder">
    <visual>
      <geometry><cylinder radius="1" length="10"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.5" length="10"/></geometry>
    </collision>
    <inertial>
      <mass value="50.0"/>
      <inertia ixx="419.8" ixy="0" ixz="0" iyy="419.8" iyz="0" izz="6.25"/>
    </inertial>
  </link>

  <!-- 3. 高处平台 -->
  <joint name="joint_mid" type="fixed">
    <parent link="slope_up"/>
    <child link="slope_mid"/>
    <origin xyz="20 0 0" rpy="0 0.2618 0"/>
  </joint>

  <link name="slope_mid">
    <visual>
      <origin xyz="10 0 0.05" rpy="0 0 0"/>
      <geometry><box size="20 10 0.1"/></geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <origin xyz="10 0 0.05" rpy="0 0 0"/>
      <geometry><box size="20 10 0.1"/></geometry>
    </collision>
    <inertial>
      <mass value="200.0"/>
      <inertia ixx="1666.8" ixy="0" ixz="0" iyy="6666.8" iyz="0" izz="8333.3"/>
    </inertial>
  </link>

  <!-- 4. 下坡 -->
  <joint name="joint_down" type="fixed">
    <parent link="slope_mid"/>
    <child link="slope_down"/>
    <origin xyz="20 0 0" rpy="0 0.2618 0"/>
  </joint>

  <link name="slope_down">
    <visual>
      <origin xyz="10 0 0.05" rpy="0 0 0"/>
      <geometry><box size="20 10 0.1"/></geometry>
      <material name="green"><color rgba="0 1 0 1"/></material>
    </visual>
    <collision>
      <origin xyz="10 0 0.05" rpy="0 0 0"/>
      <geometry><box size="20 10 0.1"/></geometry>
    </collision>
    <inertial>
      <mass value="200.0"/>
      <inertia ixx="1666.8" ixy="0" ixz="0" iyy="6666.8" iyz="0" izz="8333.3"/>
    </inertial>
  </link>

  <!-- Gazebo 物理配置 -->
  <gazebo reference="transition_cylinder"><material>Gazebo/Grey</material></gazebo>
  <gazebo reference="slope_up"><material>Gazebo/Grey</material></gazebo>
  <gazebo reference="slope_mid"><material>Gazebo/Grey</material></gazebo>
  <gazebo reference="slope_down"><material>Gazebo/Grey</material></gazebo>
  <gazebo><static>true</static></gazebo>

</robot>